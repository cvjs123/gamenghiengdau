# Chọn provider (fpt, azure, google)
TTS_PROVIDER=fpt
PORT=8787

# FPT.AI - đối với tiếng Việt
FPT_TTS_API_KEY=YOUR_FPT_API_KEY_HERE
FPT_TTS_VOICE=banmai
FPT_TTS_SPEED=1.0

# Azure (nếu dùng Azure)
# AZURE_TTS_KEY=YOUR_KEY
# AZURE_TTS_REGION=southeastasia
# AZURE_TTS_VOICE=vi-VN-HoaiMyNeural

# Google (nếu dùng Google)
# GOOGLE_TTS_API_KEY=YOUR_KEY
# GOOGLE_TTS_VOICE=vi-VN-Wavenet-A
